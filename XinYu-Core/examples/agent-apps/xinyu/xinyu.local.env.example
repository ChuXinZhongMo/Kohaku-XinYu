# Copy this file to `xinyu.local.env` and fill in your local secrets.
# Do not commit the real file.

XINYU_API_KEY=your-api-key
XINYU_BASE_URL=https://your-llm-endpoint.example/v1
# Optional OpenAI key for Codex delegated image generation via gpt-image-2.
# XINYU_OPENAI_API_KEY is mirrored to OPENAI_API_KEY for the Codex child process
# when OPENAI_API_KEY itself is not already set.
OPENAI_API_KEY=
XINYU_OPENAI_API_KEY=
# If a local/test endpoint is only available over plain HTTP, this must be
# set explicitly. Do not use it for exposed or production-like deployments.
XINYU_ALLOW_INSECURE_LLM_HTTP=0
XINYU_LLM_PROVIDER=ciallo
XINYU_LLM_MODEL=mimo-v2.5-pro
XINYU_DISABLE_STREAMING=1
# Outward renderer policy: off (default), pressure, quality, or always.
XINYU_RENDERER_MODE=off

# v1 stays shadow-only by default. Canary readiness may ask the owner before
# any limited trial, but it does not auto-enable full routing.
XINYU_V1_ENABLED=0
XINYU_V1_SHADOW_MODE=1
XINYU_V1_SHADOW_TIMEOUT_SECONDS=3
XINYU_V1_CANARY_MIN_SHADOW_TURNS=100
XINYU_V1_CANARY_MAX_ERROR_RATE=0.02
XINYU_V1_CANARY_MIN_ROUTE_DIVERSITY=1
XINYU_V1_CANARY_PROPOSAL_COOLDOWN_SECONDS=86400

# Optional TinyKernel compose shadow. It records local candidate observations
# only; it does not replace visible replies or execute tools.
XINYU_TINYKERNEL_SHADOW_ENABLED=0
XINYU_TINYKERNEL_SHADOW_ENDPOINT=http://127.0.0.1:8877/compose_shadow
XINYU_TINYKERNEL_SHADOW_TIMEOUT_SECONDS=2

# Optional local owner aliases for QQ review parsing.
XINYU_OWNER_QQ=
XINYU_OWNER_ALIASES=owner,me

# Optional owner-designated read-only directories. Use the OS path separator
# between entries (`;` on Windows). This does not grant write access.
XINYU_LOCAL_READ_DIRS=
# Optional QQ/NapCat attachment temp directories allowed for file ingest.
XINYU_QQ_ATTACHMENT_DIRS=
# Internal/private attachment URLs stay blocked unless explicitly enabled.
XINYU_ALLOW_INTERNAL_LEARNING_URLS=0

# Optional controlled search provider. Disabled by default.
# Set to duckduckgo_html only after source gates are stable.
XINYU_AUTONOMOUS_SEARCH=disabled
XINYU_AUTONOMOUS_SEARCH_MAX_QUERIES=1
XINYU_SOURCE_SEARCH_PROVIDER=disabled
XINYU_DUCKDUCKGO_HTML_ENDPOINT=https://duckduckgo.com/html/

# Optional OCR for image files and scanned PDFs.
# Windows OCR is used automatically on Windows when available.
XINYU_OCR_ENABLED=1
XINYU_OCR_MAX_PAGES=8
XINYU_OCR_TIMEOUT_SECONDS=180
# Optional custom OCR executable. It should accept one file path and print UTF-8 text.
# CPU PaddleOCR example, using PP-OCRv5 mobile models with MKLDNN disabled for Windows CPU stability:
# XINYU_OCR_COMMAND=D:\XinYu\Python312\python.exe xinyu_paddle_ocr_command.py
XINYU_OCR_COMMAND=
XINYU_OCR_LANG=chi_sim+eng

# Optional QQ voice-to-text for owner private voice messages.
# If XINYU_VOICE_STT_COMMAND is set, it is called first and should print UTF-8 transcript text.
# Local PaddleX example:
# XINYU_VOICE_STT_COMMAND=D:\XinYu\runtime\deps\ocr-venv\Scripts\python.exe D:\XinYu\XinYu-Core\examples\agent-apps\xinyu\xinyu_paddlex_voice_stt.py
# XINYU_PADDLEX_STT_MODEL=whisper_tiny
# XINYU_PADDLEX_STT_DEVICE=cpu
# XINYU_PADDLEX_STT_LANGUAGE=auto
# Otherwise the OpenAI-compatible audio transcription API is used when an API key is available.
XINYU_VOICE_STT_ENABLED=1
XINYU_VOICE_STT_COMMAND=
XINYU_VOICE_STT_API_KEY=
XINYU_VOICE_STT_BASE_URL=https://api.openai.com/v1
XINYU_VOICE_STT_MODEL=whisper-1
XINYU_VOICE_STT_LANGUAGE=zh
XINYU_VOICE_STT_TIMEOUT_SECONDS=120
XINYU_VOICE_STT_RECORD_FORMAT=mp3

# Optional local TTS playback for owner-private visible replies.
# `auto` tries chat/completions audio first, then falls back to /audio/speech.
# Current Windows playback path requires wav output.
XINYU_TTS_ENABLED=0
XINYU_TTS_BASE_URL=https://api.openai.com/v1
XINYU_TTS_API_KEY=
XINYU_TTS_MODEL=tts-1
XINYU_TTS_VOICE=alloy
XINYU_TTS_FORMAT=wav
XINYU_TTS_REQUEST_MODE=auto
XINYU_TTS_TIMEOUT_SECONDS=60
