{
  "id": "renderer_empty_reply_recovery",
  "title": "Empty visible reply is recovered through renderer",
  "input_payload": {
    "platform": "qq",
    "message_type": "private_text",
    "session_id": "scenario:owner-private",
    "user_id": "scenario-owner",
    "text": "晚上好",
    "metadata": {
      "is_owner_user": true
    }
  },
  "expected_trace_stages": [
    "outward_renderer_started",
    "outward_renderer_finished",
    "route_finished"
