  "expected_memory_impact": {
    "runtime_trace": "allowed",
    "expression_learning": "allowed",
    "approved_long_term_memory": "forbidden"
  },
  "recovery_action": {
    "kind": "automatic",
    "operator_action": "renderer retry"
  },
  "privacy_notes": "Generic greeting only."
}
